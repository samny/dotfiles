# ──────────────────────────────────────────────────────────────────────────────
# .zshenv — loaded for ALL zsh sessions (including scripts)
# Keep this minimal. Put interactive config in .zshrc.
# ──────────────────────────────────────────────────────────────────────────────

export EDITOR="code"
export LANG="en_US.UTF-8"
export ZDOTDIR="$HOME/.config/zsh"
